{
  "name": "next-globe-gen",
  "type": "module",
  "version": "0.0.0-placeholder",
  "description": "Internationalization (i18n) library for Next.js App Router",
  "author": "Joni Vainio-Kaila",
  "license": "MIT",
  "homepage": "https://next-globe-gen.dev",
  "packageManager": "pnpm@10.27.0",
  "repository": {
    "url": "https://github.com/Jon1VK/NextGlobeGen"
  },
  "keywords": [
    "react",
    "i18n",
    "internationalization",
    "localization",
    "translate",
    "translation",
    "next",
    "next.js"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "bin": {
    "next-globe-gen": "./dist/cli.mjs"
  },
  "types": "./dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client.d.mts",
      "react-server": "./dist/server.mjs",
      "default": "./dist/client.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "default": "./dist/client.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "default": "./dist/config.mjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.mts",
      "default": "./dist/middleware.mjs"
    },
    "./proxy": {
      "types": "./dist/proxy.d.mts",
      "default": "./dist/proxy.mjs"
    },
    "./plugin": {
      "types": "./dist/plugin.d.mts",
      "default": "./dist/plugin.mjs"
    }
  },
  "scripts": {
    "build": "pnpm run --sequential /^build:/",
    "build:package": "tsdown",
    "build:key-extractor": "cd ../key-extractor && pnpm run build && cp ./target/wasm32-wasip1/release/key_extractor.wasm ../package/dist/key_extractor.wasm",
    "check": "pnpm run /^check:/",
    "check:types": "tsc",
    "check:lint": "eslint .",
    "check:format": "prettier --check .",
    "test": "vitest --no-watch",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@formatjs/icu-messageformat-parser": "^3.5.10",
    "@swc/core": "^1.15.40",
    "commander": "^15.0.0",
    "fast-memoize": "^2.5.2",
    "gettext-parser": "^9.0.2",
    "intl-messageformat": "^11.2.7",
    "negotiator": "^1.0.0",
    "path-to-regexp": "^8.4.2",
    "tsdown": "^0.22.1",
    "tsup": "^8.5.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/gettext-parser": "^9.0.0",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.1",
    "next": "^16.2.6",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "next": "^15.3.0 || ^16.0.0",
    "react": "^19.0.0"
  }
}
